<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN>

<PLUGIN
  name="{{ name }}"
  author="{{ author }}"
  version="{{ env['PLUGIN_VERSION'] }}"
  launch="Settings/{{ name }}"
  pluginURL="https://raw.githubusercontent.com/{{ env['GITHUB_REPOSITORY'] }}/main/plugin/{{ name }}{{ env['PLUGIN_RELEASE'] }}.plg"
  {% if icon is defined %}icon="{{ icon }}"{% endif %}
  {% if min is defined %}min="{{ min }}"{% endif %}
  project="https://github.com/{{ env['GITHUB_REPOSITORY'] }}"
  readme="https://github.com/{{ env['GITHUB_REPOSITORY'] }}#readme"
>

<CHANGES>
<![CDATA[
{{ env['PLUGIN_CHANGELOG'] }}

For older releases, see https://github.com/{{ env['GITHUB_REPOSITORY'] }}/releases
]]>
</CHANGES>

<!--
===========================================
PRE-INSTALL SCRIPT
Clean old package versions
===========================================
-->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
# Remove old package versions
rm -f $(ls /boot/config/plugins/{{ name }}/{{ package_name }}-*.txz 2>/dev/null | grep -v '{{ env['PLUGIN_VERSION'] }}')

# Create plugin directory if needed
mkdir -p /boot/config/plugins/{{ name }}
mkdir -p /boot/config/plugins/{{ name }}/logs
]]>
</INLINE>
</FILE>

<!--
===========================================
PACKAGE INSTALLATION
Download and install the main package
===========================================
-->
<FILE Name="/boot/config/plugins/{{ name }}/{{ package_name }}-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz">
<URL>https://github.com/{{ env['GITHUB_REPOSITORY'] }}/releases/download/{{ env['PLUGIN_TAG'] }}/{{ package_name }}-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz</URL>
<SHA256>{{ env['PLUGIN_CHECKSUM'] }}</SHA256>
</FILE>

<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
upgradepkg --install-new /boot/config/plugins/{{ name }}/{{ package_name }}-{{ env['PLUGIN_VERSION'] }}-noarch-1.txz
]]>
</INLINE>
</FILE>

<!--
===========================================
POST-INSTALL SCRIPT
===========================================
-->
<FILE Run="/bin/bash">
<INLINE>
<![CDATA[
# Set script permissions
chmod +x /usr/local/emhttp/plugins/{{ name }}/scripts/*.sh 2>/dev/null

# Create cron file in plugin config dir (Unraid's update_cron reads *.cron from here)
echo "0 * * * * /usr/local/emhttp/plugins/{{ name }}/scripts/check.sh >> /boot/config/plugins/{{ name }}/logs/cron.log 2>&1" > /boot/config/plugins/{{ name }}/{{ name }}.cron

# Remove legacy cron file if present (old versions wrote directly to /etc/cron.d/)
rm -f /etc/cron.d/{{ name }}

# Regenerate system crontab
/usr/local/sbin/update_cron

# Run install script (initializes config/state if needed, pass version since PLG isn't written yet)
/usr/local/emhttp/plugins/{{ name }}/scripts/install.sh "{{ env['PLUGIN_VERSION'] }}"

echo ""
echo "----------------------------------------------------"
echo " {{ name }} has been installed."
echo " Version: {{ env['PLUGIN_VERSION'] }}"
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

<!--
===========================================
REMOVE SCRIPT
===========================================
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
<![CDATA[
# Stop external API server
/usr/local/emhttp/plugins/{{ name }}/scripts/stop-api.sh 2>/dev/null

# Remove cron file and regenerate system crontab
rm -f /boot/config/plugins/{{ name }}/{{ name }}.cron
rm -f /etc/cron.d/{{ name }}
/usr/local/sbin/update_cron

# Remove the package
removepkg {{ package_name }} 2>/dev/null

# Remove plugin files from RAM
rm -rf /usr/local/emhttp/plugins/{{ name }}

echo ""
echo "----------------------------------------------------"
echo " {{ name }} has been removed."
echo " Config preserved at /boot/config/plugins/{{ name }}/"
echo " Delete that directory manually for a clean removal."
echo "----------------------------------------------------"
echo ""
]]>
</INLINE>
</FILE>

</PLUGIN>
